# Checkerboard Pattern using Nested For Loops

# The outer loop controls the rows.
for row in range(5):

    # The inner loop controls the columns.
    for col in range(5):

        # Print '*' when row + column is even,
        # otherwise print '.'
        if (row + col) % 2 == 0:
            print("*", end=" ")
        else:
            print(".", end=" ")

    # Move to the next row
    print()